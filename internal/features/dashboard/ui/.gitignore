# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

node_modules
# The built SPA bundle is generated (by `npm run build`) and embedded by Go, so
# it is never committed — but the directory itself must stay tracked so
# `//go:embed all:ui/dist` has something to embed on a fresh checkout. Ignore
# everything under dist/ except the .gitkeep placeholder.
dist/*
!dist/.gitkeep
dist-ssr
.DS_Store
*.local

# Editor directories and files
.vscode/*
!.vscode/extensions.json
.idea
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# vue-tsc / test coverage
*.tsbuildinfo
coverage

# Stray tsc outputs of the *.config.ts sources (never commit compiled configs)
*.config.js
*.config.d.ts
